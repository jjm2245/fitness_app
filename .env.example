# Copy to .env for local dev. In production (Vercel), set these as project
# environment variables instead — never commit real values.

# Local dev: local Postgres over a Unix socket (see README "Local Postgres").
# Production: a managed Postgres connection string (Neon's *pooled* endpoint
# recommended — see DECISIONS.md). Must include sslmode=require in production.
DATABASE_URL="postgresql://fitness_app@localhost:5433/fitness_app?host=/tmp"

# The single device passcode gating the whole app. Pick something you
# wouldn't mind typing on your phone but isn't guessable.
APP_PASSCODE="change-me"

# Signs the session cookie. Must be a separate, high-entropy secret from
# APP_PASSCODE — generate with: openssl rand -hex 32
SESSION_SECRET="change-me-too"
